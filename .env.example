# Copy this file to `.env` and fill in your values.
#   cp .env.example .env

# ── REQUIRED: Cloudflare authentication ──────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── OPTIONAL: real AI provider (leave blank to keep mock AI) ──
# ANTHROPIC_API_KEY=

# ── OPTIONAL: custom domain (leave blank to use *.workers.dev) ─
# CUSTOM_DOMAIN=

# ── GitHub (for pushing the repo) ──
GITHUB_TOKEN=
