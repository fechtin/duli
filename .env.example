# Copy this file to `.env` and fill in your values.
#   cp .env.example .env

# ── REQUIRED: Cloudflare authentication ──────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── OPTIONAL: real AI provider (leave blank to keep mock AI) ──
# ANTHROPIC_API_KEY=

# ── OPTIONAL: custom domain (leave blank to use *.workers.dev) ─
# CUSTOM_DOMAIN=

# ── GitHub (for pushing the repo) ──
GITHUB_TOKEN=

# ── Firebase (Google login + photo storage) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
